{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES6"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "rootDir": "./src",
    "outDir": "dist",
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
