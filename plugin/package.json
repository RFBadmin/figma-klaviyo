{
  "name": "figma-klaviyo-plugin",
  "version": "1.0.0",
  "description": "Figma to Klaviyo AI Plugin",
  "scripts": {
    "build": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es6 && esbuild src/ui.tsx --bundle --outfile=dist/ui.js --target=es6 --jsx=automatic --jsx-import-source=preact && node build-ui.js",
    "watch": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es6 --watch & esbuild src/ui.tsx --bundle --outfile=dist/ui.js --target=es6 --jsx=automatic --jsx-import-source=preact --watch",
    "dev": "npm run watch"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.95.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "preact": "^10.19.0"
  }
}
