# Copy this file to .env and fill in your values
# cp .env.example .env   (macOS/Linux)
# copy .env.example .env  (Windows)

ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
BASE_URL=http://localhost:8080
FLASK_DEBUG=0
PORT=8080

# Fernet key for encrypting brand API keys in brands.json.
# One developer generates this ONCE and sets it in Railway's env vars dashboard.
# Team members never generate their own — everyone uses the same key so encrypted
# data can be read back by the server.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BRANDS_SECRET=

# Optional: shared secret to protect expensive endpoints (analyze, compress, brands).
# If set, the plugin must send this value in the X-Plugin-Secret header.
# Leave empty to disable auth (for local dev).
PLUGIN_SECRET=
